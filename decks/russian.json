{
  "id": "russian-basics",
  "title": "Russisk for nybegynnere",
  "language": { "front": "ru", "back": "en" },
  "explainContext": "The user is learning Russian from English, beginner level (A0-A1). Explain in English. Use simple transliteration when helpful.",
