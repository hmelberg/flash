        { "id": "cloze-knigu", "front": "Я читаю ___. (книга)", "back": "книгу", "tts": "я читаю книгу" },
        { "id": "cloze-vodu", "front": "Он пьёт ___. (вода)", "back": "воду", "tts": "он пьёт воду" },
        { "id": "acc-masc-inanimate", "front": "Accusative of masculine inanimate nouns?", "back": "Same as nominative: Я вижу дом (no change)", "tts": "я вижу дом" },
        { "id": "acc-masc-animate", "front": "Accusative of masculine animate nouns?", "back": "Takes the genitive form: Я вижу друга (друг → друга)", "tts": "я вижу друга" },
        { "id": "cloze-druga", "front": "Я знаю ___. (друг)", "back": "друга", "tts": "я знаю друга" },
        { "id": "acc-neuter", "front": "Accusative of neuter nouns?", "back": "Same as nominative: Я вижу окно", "tts": "я вижу окно" }
      ]
    },
