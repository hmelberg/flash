      "cards": [
        { "id": "gender-rule", "front": "How do you usually tell a Russian noun's gender?", "back": { "html": "By the last letter:<table><tr><th>ends in</th><th>gender</th></tr><tr><td>consonant</td><td>masculine</td></tr><tr><td>-а / -я</td><td>feminine</td></tr><tr><td>-о / -е</td><td>neuter</td></tr></table>" } },
        { "id": "dom", "front": "дом", "back": "house (m)", "reverse": true, "tts": "дом", "example": { "text": "Это мой дом.", "translation": "This is my house." } },
        { "id": "voda", "front": "вода", "back": "water (f)", "reverse": true, "tts": "вода", "example": { "text": "Я пью воду.", "translation": "I drink water." } },
        { "id": "okno", "front": "окно", "back": "window (n)", "reverse": true, "tts": "окно" },
        { "id": "kniga", "front": "книга", "back": "book (f)", "reverse": true, "tts": "книга", "example": { "text": "Это интересная книга.", "translation": "This is an interesting book." } },
        { "id": "stol", "front": "стол", "back": "table (m)", "reverse": true, "tts": "стол" },
        { "id": "mama-papa", "front": "мама / папа", "back": "mom / dad (папа is masculine despite -а!)", "tts": "мама, папа", "hint": "Natural gender beats the ending" },
        { "id": "gorod", "front": "город", "back": "city (m)", "reverse": true, "tts": "город", "example": { "text": "Москва — большой город.", "translation": "Moscow is a big city." } },
        { "id": "drug", "front": "друг", "back": "friend (m)", "reverse": true, "tts": "друг", "example": { "text": "Он мой друг.", "translation": "He is my friend." } },
        { "id": "gender-quiz", "front": "Gender of: машина, море, чай?", "back": "машина — f (-а), море — n (-е), чай — m (ends in й)", "tts": "машина, море, чай" }
      ]
    },
