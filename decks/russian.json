      "cards": [
        { "id": "ya", "front": "я", "back": "I", "reverse": true, "tts": "я" },
        { "id": "ty", "front": "ты", "back": "you (informal singular)", "reverse": true, "tts": "ты" },
        { "id": "on-ona", "front": "он / она / оно", "back": "he / she / it", "tts": "он, она, оно" },
        { "id": "my", "front": "мы", "back": "we", "reverse": true, "tts": "мы" },
        { "id": "vy", "front": "вы", "back": "you (plural or formal)", "reverse": true, "tts": "вы" },
        { "id": "oni", "front": "они", "back": "they", "reverse": true, "tts": "они" },
        { "id": "byt-present", "front": "How do you say «I am a student» in Russian?", "back": "Я студент — the verb 'to be' is dropped in the present tense", "tts": "я студент" },
        { "id": "eto", "front": "это", "back": "this (is) / it (is)", "tts": "это", "example": { "text": "Это дом.", "translation": "This is a house." } },
        { "id": "kto-chto", "front": "кто / что", "back": "who / what", "tts": "кто, что", "example": { "text": "Кто это? Что это?", "translation": "Who is this? What is this?" } },
        { "id": "moj-tvoj", "front": "мой / твой", "back": "my / your (informal)", "tts": "мой, твой", "hint": "Agrees with gender: мой дом, моя мама, моё окно" }
      ]
    },
    {
