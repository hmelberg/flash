        { "id": "rabotat", "front": "работать", "back": "to work", "reverse": true, "tts": "работать", "example": { "text": "Она работает дома.", "translation": "She works at home." } },
        { "id": "pit", "front": "пить", "back": "to drink", "reverse": true, "tts": "пить", "example": { "text": "Мы пьём чай.", "translation": "We drink tea." } },
