  "lessons": [
    {
      "id": "l01-alphabet",
      "title": "Alfabetet og uttale",
      "note": "Kyrilliske bokstaver som ser kjente ut men uttales annerledes, og de helt nye. Lyttetrening: bruk 🔊.",
      "cards": [
        { "id": "cyr-v", "front": "How is the letter «В в» pronounced?", "back": "Like English v (not b!)", "hint": "вода = voda", "tts": "в" },
        { "id": "cyr-n", "front": "How is the letter «Н н» pronounced?", "back": "Like English n (not h!)", "tts": "н" },
        { "id": "cyr-r", "front": "How is the letter «Р р» pronounced?", "back": "Rolled r (not p!)", "tts": "р" },
        { "id": "cyr-s", "front": "How is the letter «С с» pronounced?", "back": "Like English s", "tts": "с" },
        { "id": "cyr-u", "front": "How is the letter «У у» pronounced?", "back": "Like oo in 'moon'", "tts": "у" },
        { "id": "cyr-zh", "front": "How is the letter «Ж ж» pronounced?", "back": "Like s in 'pleasure' (zh)", "tts": "ж" },
        { "id": "cyr-ch", "front": "How is the letter «Ч ч» pronounced?", "back": "Like ch in 'church'", "tts": "ч" },
        { "id": "cyr-sh", "front": "How is the letter «Ш ш» pronounced?", "back": "Like sh in 'ship'", "tts": "ш" },
        { "id": "cyr-y", "front": "How is the letter «Ы ы» pronounced?", "back": "A deep 'i' with the tongue pulled back — no exact English equivalent", "hint": "ты, мы, вы", "tts": "ы" },
        { "id": "cyr-ja", "front": "How is the letter «Я я» pronounced?", "back": "Like ya in 'yard'", "tts": "я" },
        { "id": "cyr-e", "front": "How is the letter «Э э» pronounced?", "back": "Like e in 'end'", "tts": "э" },
        { "id": "cyr-softsign", "front": "What does the soft sign «ь» do?", "back": "No sound of its own — it softens (palatalizes) the preceding consonant", "hint": "день, мать" }
      ]
    },
    {
      "id": "l02-greetings",
      "title": "Hilsener og høflighet",
      "cards": [
        { "id": "privet", "front": "привет", "back": "hi (informal)", "reverse": true, "tts": "привет", "example": { "text": "Привет, как дела?", "translation": "Hi, how are things?" } },
        { "id": "zdravstvujte", "front": "здравствуйте", "back": "hello (formal)", "reverse": true, "tts": "здравствуйте", "hint": "Literally a wish of good health" },
        { "id": "dobroe-utro", "front": "доброе утро", "back": "good morning", "reverse": true, "tts": "доброе утро" },
        { "id": "dobryj-den", "front": "добрый день", "back": "good afternoon", "reverse": true, "tts": "добрый день" },
        { "id": "spasibo", "front": "спасибо", "back": "thank you", "reverse": true, "tts": "спасибо", "example": { "text": "Спасибо большое!", "translation": "Thank you very much!" } },
        { "id": "pozhalujsta", "front": "пожалуйста", "back": "please / you're welcome", "reverse": true, "tts": "пожалуйста", "hint": "Does double duty: request and reply to thanks" },
        { "id": "da-net", "front": "да / нет", "back": "yes / no", "tts": "да, нет" },
        { "id": "izvinite", "front": "извините", "back": "excuse me / sorry (formal)", "reverse": true, "tts": "извините" },
        { "id": "poka", "front": "пока", "back": "bye (informal)", "reverse": true, "tts": "пока" },
        { "id": "do-svidanija", "front": "до свидания", "back": "goodbye (formal)", "reverse": true, "tts": "до свидания", "hint": "Literally 'until the (next) meeting'" },
        { "id": "kak-dela", "front": "Как дела?", "back": "How are things?", "reverse": true, "tts": "как дела", "example": { "text": "— Как дела? — Хорошо, спасибо.", "translation": "— How are things? — Good, thanks." } },
        { "id": "menya-zovut", "front": "Меня зовут…", "back": "My name is…", "reverse": true, "tts": "меня зовут", "hint": "Literally 'they call me…'" }
      ]
    },
    {
      "id": "l03-pronouns-byt",
