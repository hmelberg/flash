    {
      "id": "l03-phrases",
      "title": "Survival phrases",
      "intro": "## Phrases as chunks\n\nDon't analyse these word by word yet — learn them as **whole chunks** you can say without thinking. Fluency starts with a stock of ready-made phrases; the grammar behind them comes later.\n\nTwo symbols to know: Spanish questions open with **¿** and exclamations with **¡** — they tell you the intonation *before* you start reading.",
      "cards": [
        { "id": "como-estas", "front": "¿Cómo estás?", "back": "How are you?", "tts": "¿Cómo estás?", "reverse": true,
          "example": { "text": "¡Hola, María! ¿Cómo estás?", "translation": "Hi, María! How are you?" } },
        { "id": "me-llamo", "front": "Me llamo …", "back": "My name is …", "tts": "Me llamo", "reverse": true,
          "example": { "text": "Me llamo Ana, ¿y tú?", "translation": "My name is Ana, and you?" } },
        { "id": "mucho-gusto", "front": "mucho gusto", "back": "nice to meet you", "tts": "mucho gusto", "reverse": true },
        { "id": "donde-esta", "front": "¿Dónde está …?", "back": "Where is …?", "tts": "¿Dónde está?", "reverse": true,
          "example": { "text": "¿Dónde está la estación?", "translation": "Where is the station?" } },
        { "id": "no-entiendo", "front": "no entiendo", "back": "I don't understand", "tts": "no entiendo", "reverse": true,
          "example": { "text": "Perdón, no entiendo. ¿Puede repetir?", "translation": "Sorry, I don't understand. Can you repeat?" } },
        { "id": "cuanto-cuesta", "front": "¿Cuánto cuesta?", "back": "How much does it cost?", "tts": "¿Cuánto cuesta?", "reverse": true,
          "example": { "text": "¿Cuánto cuesta este libro?", "translation": "How much does this book cost?" } },
        { "id": "lo-siento", "front": "lo siento", "back": "I'm sorry", "tts": "lo siento", "reverse": true },
        { "id": "hasta-luego", "front": "hasta luego", "back": "see you later", "tts": "hasta luego", "reverse": true,
          "example": { "text": "Me voy. ¡Hasta luego!", "translation": "I'm off. See you later!" } }
      ]
    }
  ]
